# Ejemplo de configuracion por entorno (Fase 3 / Fase 4).
# Copia este archivo a .env y ajusta los valores. NO subas tu .env real.
# Todos los valores aqui son FICTICIOS.

# --- Django ---
# Genera una con: python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=clave-ficticia
# 0 = uso interno/produccion (DEBUG off). 1 = desarrollo.
DJANGO_DEBUG=0
# Agrega el nombre de la PC y su IP local para acceder desde otras maquinas.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,NOMBRE-PC,IP-LOCAL

# --- Rutas del motor (ubicacion controlada del Excel y salidas) ---
RFQ_ARCHIVO_MAESTRO=C:\ruta\controlada\PROYECTO.xlsx
RFQ_CARPETA_BACKUPS=C:\ruta\controlada\backups
RFQ_CARPETA_REPORTES=C:\ruta\controlada\reportes

# --- Rutas Django ---
RFQ_MEDIA_ROOT=C:\ruta\controlada\media
RFQ_LOGS_DIR=C:\ruta\controlada\logs
# RFQ_STATIC_ROOT=C:\ruta\controlada\staticfiles

# --- Waitress (servidor interno) ---
# 127.0.0.1 = solo esta PC. 0.0.0.0 = accesible desde la red local.
RFQ_WAITRESS_HOST=0.0.0.0
RFQ_WAITRESS_PORT=8000
