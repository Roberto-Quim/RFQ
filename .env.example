# Ejemplo de configuracion por entorno (Fase 3).
# Copia este archivo a .env y ajusta los valores. NO subas tu .env real.
# Todos los valores aqui son FICTICIOS.

# --- Django ---
# Genera una con: python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=pon-aqui-una-clave-larga-y-secreta
# 1 = desarrollo (DEBUG on). En uso real/compartido usar 0.
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# --- Rutas del motor (opcionales; si se omiten se usan las de por defecto) ---
# Ruta al archivo maestro de Excel.
RFQ_ARCHIVO_MAESTRO=C:\ruta\a\PROYECTO.xlsx
# Carpetas (opcionales)
# RFQ_CARPETA_BACKUPS=C:\ruta\a\backups
# RFQ_CARPETA_REPORTES=C:\ruta\a\reportes

# --- Rutas Django (opcionales) ---
# RFQ_MEDIA_ROOT=C:\ruta\a\media
# RFQ_LOGS_DIR=C:\ruta\a\logs
