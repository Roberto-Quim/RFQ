# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
env/

# Excel / datos reales
PROYECTO.xlsx
*.xls
*.xlsx
*.xlsm
!requirements.txt

# Entradas y salidas del proceso
entrada/*
procesados/*
backups/*
reportes/*
muestras/*

# Correos / RFQ reales / datos sensibles
*.eml
*.msg
*.pdf
*.docx
*.txt

# Permitir archivos placeholder si luego los quieres agregar
!entrada/.gitkeep
!procesados/.gitkeep
!backups/.gitkeep
!reportes/.gitkeep
!muestras/.gitkeep

# Django (Fase 2)
# (los comentarios en .gitignore deben ir en su PROPIA linea, no al final del patron)
# BD local: puede contener datos reales del historial
db.sqlite3
db.sqlite3-journal
# archivos subidos por los usuarios (RFQ .txt)
media/
# estaticos recolectados (collectstatic)
staticfiles/
# NOTA: las migraciones (seguimiento/migrations/*.py) SI se versionan: son
# estructura, no datos. Solo el __pycache__ queda excluido (regla de arriba).

# Sistema / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Permitir requirements aunque sea .txt
!requirements.txt
